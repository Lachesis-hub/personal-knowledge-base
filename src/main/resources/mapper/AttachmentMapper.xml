<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.personalkb.mapper.AttachmentMapper">


    <insert id="insert"
            useGeneratedKeys="true"
            keyProperty="id">

        insert into attachment
        (
        user_id,
        knowledge_id,
        file_name,
        file_path,
        file_size
        )
        values
        (
        #{userId},
        #{knowledgeId},
        #{fileName},
        #{filePath},
        #{fileSize}
        )

    </insert>



    <select id="selectByUserId"
            resultType="com.personalkb.entity.Attachment">

        select *
        from attachment
        where user_id = #{userId}
        order by id desc

    </select>



    <select id="selectById"
            resultType="com.personalkb.entity.Attachment">

        select *
        from attachment
        where id = #{id}

    </select>



    <delete id="deleteById">

        delete
        from attachment
        where id = #{id}

    </delete>


</mapper>